# Ce fichier est un modèle (committé). Vite charge automatiquement en réalité :
#   - .env.development (npm run dev)
#   - .env.production (npm run build)
# Ces deux fichiers réels sont ignorés par git (.gitignore).
#
# URL de base de l'API backend, utilisée par l'app React (frontend/src/services/apiClient.js).
# Si absente, l'app suppose que le backend tourne sur le port 3000 du même hôte que le site.
VITE_API_BASE_URL=http://localhost:3000/api
