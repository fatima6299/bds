# Ce fichier est un modèle (committé). Le serveur charge en réalité :
#   - .env.development en local (npm run dev, valeur par défaut de NODE_ENV)
#   - .env.production sur le serveur de prod (NODE_ENV=production)
#   - .env comme repli si le fichier ci-dessus n'existe pas
# Ces trois fichiers réels sont ignorés par git (.gitignore) : copiez ce modèle
# pour en créer un nouveau si besoin.

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bds
# Mettre à true si l'hébergeur MySQL managé (Railway, Clever Cloud...) l'exige
DB_SSL=false

# JWT Configuration
# Générer une vraie valeur avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Ne JAMAIS utiliser une valeur d'exemple en production.
JWT_SECRET=changez_moi_avec_un_secret_aleatoire_genere
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS - domaines autorisés à appeler l'API (séparés par des virgules)
# En production, remplacer par le(s) vrai(s) domaine(s) du site (ex: https://bds-business.com)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
